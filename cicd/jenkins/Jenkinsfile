pipeline {
    agent any

    environment {
        DOCKER_HUB_REPO = "gigconnect"
        BACKEND_IMAGE   = "${DOCKER_HUB_REPO}-api"
        FRONTEND_IMAGE  = "${DOCKER_HUB_REPO}-web"
        JAVA_HOME       = tool 'JDK21'
        PATH            = "${JAVA_HOME}/bin:${env.PATH}"
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "Building branch: ${env.GIT_BRANCH} | Commit: ${env.GIT_COMMIT}"
            }
        }

        stage('Backend Tests') {
            steps {
                dir('backend') {
                    sh 'chmod +x mvnw'
                    sh './mvnw test -q'
                }
            }
            post {
                always {
                    junit 'backend/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Frontend Tests') {
            steps {
                dir('frontend') {
                    sh 'npm ci'
                    sh 'npm run lint --if-present'
                    sh 'npm run build'
                }
            }
        }

        stage('Build Backend JAR') {
            steps {
                dir('backend') {
                    sh './mvnw package -DskipTests -q'
                }
            }
        }

        stage('Docker Build') {
            when { branch 'main' }
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-creds',
                                                  usernameVariable: 'DOCKER_USER',
                                                  passwordVariable: 'DOCKER_PASS')]) {
                    sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                    sh """
                        docker build -f cicd/Dockerfile.backend \
                          -t ${DOCKER_USER}/${BACKEND_IMAGE}:${env.GIT_COMMIT} \
                          -t ${DOCKER_USER}/${BACKEND_IMAGE}:latest .

                        docker build -f cicd/Dockerfile.frontend \
                          --build-arg VITE_API_URL=/api/v1 \
                          -t ${DOCKER_USER}/${FRONTEND_IMAGE}:${env.GIT_COMMIT} \
                          -t ${DOCKER_USER}/${FRONTEND_IMAGE}:latest .

                        docker push ${DOCKER_USER}/${BACKEND_IMAGE}:${env.GIT_COMMIT}
                        docker push ${DOCKER_USER}/${BACKEND_IMAGE}:latest
                        docker push ${DOCKER_USER}/${FRONTEND_IMAGE}:${env.GIT_COMMIT}
                        docker push ${DOCKER_USER}/${FRONTEND_IMAGE}:latest
                    """
                }
            }
        }

        stage('Deploy to Render') {
            when { branch 'main' }
            steps {
                withCredentials([
                    string(credentialsId: 'render-hook-backend',  variable: 'HOOK_BACKEND'),
                    string(credentialsId: 'render-hook-frontend', variable: 'HOOK_FRONTEND')
                ]) {
                    sh 'curl -s --fail -X POST "$HOOK_BACKEND"'
                    sh 'curl -s --fail -X POST "$HOOK_FRONTEND"'
                }
            }
        }

        stage('Smoke Test') {
            when { branch 'main' }
            steps {
                sleep(time: 90, unit: 'SECONDS')
                sh 'curl --retry 5 --retry-delay 15 --fail https://gigconnect-api.onrender.com/api/v1/actuator/health'
            }
        }
    }

    post {
        success {
            echo "✅ Pipeline succeeded — ${env.GIT_COMMIT}"
        }
        failure {
            echo "❌ Pipeline failed — check logs above"
        }
        always {
            sh 'docker system prune -f || true'
        }
    }
}
